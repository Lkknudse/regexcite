system("git remote -v")
use_git()
library(devtools)
use_git()
library(usethis)
use_github()
strsplit1 <- function(x, split) {
strsplit(x, split = split)[[1]]
}
getwd()
load_all()
library(devtools)
load_all()
(x <- "alfa,bravo,charlie,delta")
#> [1] "alfa,bravo,charlie,delta"
strsplit1(x, split = ",")
#> [1] "alfa"    "bravo"   "charlie" "delta"
exists("strsplit1", where = globalenv(), inherits = FALSE)
#> [1] FALSE
check()
use_mit_license()
#> ✔ Adding "MIT + file LICENSE" to 'License'.
